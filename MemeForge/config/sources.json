{
  "image_sources": {
    "apis": [
      {
        "name": "picsum",
        "url_template": "https://picsum.photos/{width}/{height}",
        "parameters": {
          "width": 800,
          "height": 600
        },
        "description": "Images aléatoires de haute qualité",
        "rate_limit": 10,
        "requires_auth": false
      },
      {
        "name": "unsplash",
        "url_template": "https://source.unsplash.com/random/{width}x{height}",
        "parameters": {
          "width": 800,
          "height": 600
        },
        "description": "Photos artistiques aléatoires",
        "rate_limit": 5,
        "requires_auth": false
      },
      {
        "name": "placeholder",
        "url_template": "https://via.placeholder.com/{width}x{height}/{background}/{foreground}",
        "parameters": {
          "width": 800,
          "height": 600,
          "background": "000000",
          "foreground": "ffffff"
        },
        "description": "Placeholders avec texte personnalisable",
        "rate_limit": 100,
        "requires_auth": false
      }
    ],
    
    "thematic_collections": {
      "cyberpunk": [
        "https://images.unsplash.com/photo-1548092372-0d1bd40894a3",
        "https://images.unsplash.com/photo-1550745165-9bc0b252726f",
        "https://images.unsplash.com/photo-1488590528505-98d2b5aba04b"
      ],
      "glitch_art": [
        "https://images.unsplash.com/photo-1578662996442-48f60103fc96",
        "https://images.unsplash.com/photo-1550684376-efcbd6e3f031",
        "https://images.unsplash.com/photo-1547036967-23d11aacaee0"
      ],
      "urban_decay": [
        "https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91",
        "https://images.unsplash.com/photo-1560518883-ce09059eeffa",
        "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab"
      ],
      "nature_fractale": [
        "https://images.unsplash.com/photo-1578662996442-48f60103fc96",
        "https://images.unsplash.com/photo-1613535449480-bb56b88d1886",
        "https://images.unsplash.com/photo-1550684376-efcbd6e3f031"
      ],
      "abstrait_technologique": [
        "https://images.unsplash.com/photo-1635070041078-e363dbe005cb",
