        "https://images.unsplash.com/photo-1563089145-599997674d42"
      ]
    },
    
    "local_sources": {
      "patterns": [
        "./sources/patterns/*.jpg",
        "./sources/patterns/*.png",
        "./sources/backgrounds/*.webp"
      ],
      "textures": [
        "./sources/textures/concrete_*.jpg",
        "./sources/textures/metal_*.png",
        "./sources/textures/digital_*.jpg"
      ],
      "portraits": [
        "./sources/portraits/cyber_*.jpg",
        "./sources/portraits/abstract_*.png"
      ]
    }
  },
  
  "news_feeds": {
    "international": [
      {
        "name": "bbc_world",
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "language": "en",
        "reliability": 0.9,
        "update_frequency": 30
      },
      {
        "name": "reuters_world",
        "url": "https://www.reutersagency.com/feed/?best-topics=world-news&post_type=best",
        "language": "en",
        "reliability": 0.85,
        "update_frequency": 15
      },
      {
        "name": "france24",
        "url": "https://www.france24.com/fr/rss",
        "language": "fr",
        "reliability": 0.8,
        "update_frequency": 20
      }
    ],
    
    "technology": [
      {
        "name": "techcrunch",
        "url": "https://techcrunch.com/feed/",
        "language": "en",
        "reliability": 0.75,
        "update_frequency": 10
      },
      {
        "name": "wired_tech",
        "url": "https://www.wired.com/feed/rss",
        "language": "en", 
        "reliability": 0.8,
        "update_frequency": 25
      },
      {
        "name": "numerama",
        "url": "https://www.numerama.com/feed/",
        "language": "fr",
        "reliability": 0.7,
        "update_frequency": 30
      }
    ],
    
    "alternative": [
      {
        "name": "vice_tech",
        "url": "https://www.vice.com/en/rss?topics=technology",
        "language": "en",
        "reliability": 0.6,
        "update_frequency": 40
      },
      {
        "name": "the_verge_cyber",
        "url": "https://www.theverge.com/cyber/rss/index.xml",
        "language": "en",
        "reliability": 0.75,
        "update_frequency": 15
      }
    ]
  },
  
  "ar_content_sources": {
    "mystery_urls": [
      "https://archive.org/details/audio",
      "https://www.gutenberg.org/ebooks/search/?query=mystery",
      "https://openlibrary.org/search.json?q=esoteric",
      "data:text/plain;base64,{}",
      "geo:{},{};u={}"
    ],
    
    "hidden_services": [
      "http://localhost:8080/ar/{}",
      "https://hidden-service.onion/portal/{}",
      "ipfs://{}"
    ],
    
    "coordinate_templates": [
      "geo:{lat},{lon};u=10",
      "geo:{lat},{lon},{alt}",
      "https://www.openstreetmap.org/?mlat={lat}&mlon={lon}&zoom=15"
    ]
  },
  
  "data_sources": {
    "symbol_databases": [
      {
        "name": "unicode_symbols",
        "url": "https://unicode.org/Public/UNIDATA/UnicodeData.txt",
        "type": "text",
        "description": "Base de données complète des symboles Unicode"
      },
      {
        "name": "emoji_data",
        "url": "https://unicode.org/Public/emoji/latest/emoji-test.txt",
        "type": "text",
        "description": "Définitions et codes emoji"
      }
    ],
    
    "color_palettes": [
      {
        "name": "cyberpunk_colors",
        "colors": ["#ff0055", "#00ffff", "#ffcc00", "#6600ff", "#00ff88"],
        "description": "Palette néon cyberpunk"
      },
      {
        "name": "glitch_colors", 
        "colors": ["#ff0000", "#0000ff", "#00ff00", "#ffff00", "#ff00ff"],
        "description": "Couleurs primaires saturées pour effets glitch"
      },
      {
        "name": "vintage_colors",
        "colors": ["#8b4513", "#2f4f4f", "#696969", "#daa520", "#800000"],
        "description": "Palette sépia et tons vintage"
      }
    ],
    
    "font_sources": [
      {
        "name": "google_fonts",
        "api_key": "YOUR_GOOGLE_FONTS_API_KEY",
        "endpoint": "https://www.googleapis.com/webfonts/v1/webfonts",
        "popular_fonts": ["Roboto", "Open Sans", "Lato", "Montserrat"]
      },
      {
        "name": "local_fonts",
        "paths": [
          "/usr/share/fonts/truetype/",
          "/usr/local/share/fonts/",
          "~/.fonts/",
          "./fonts/"
        ],
        "fallback_fonts": ["Arial", "Helvetica", "Times New Roman"]
      }
    ]
  },
  
  "api_configurations": {
    "image_processing": {
      "max_file_size": 10485760,
      "allowed_formats": ["jpg", "jpeg", "png", "webp", "gif"],
      "timeout": 30,
      "retry_attempts": 3
    },
    
    "rate_limits": {
      "images_per_minute": 60,
      "news_requests_per_hour": 100,
      "api_calls_per_day": 1000
    },
    
    "cache_settings": {
      "image_cache_ttl": 3600,
      "news_cache_ttl": 900,
      "max_cache_size": 1073741824
    }
  },
  
  "webhook_endpoints": {
    "success_notifications": [
      "https://discord.com/api/webhooks/your-channel-id/your-token",
      "https://hooks.slack.com/services/your/webhook/path"
    ],
    
    "error_reporting": [
      "https://api.rollbar.com/api/1/item/",
      "https://sentry.io/api/your-project/store/"
    ],
    
    "analytics": [
      "https://www.google-analytics.com/collect",
      "https://api.mixpanel.com/track"
    ]
  },
  
  "backup_sources": {
    "fallback_images": [
      "https://picsum.photos/800/600?random=1",
      "https://source.unsplash.com/random/800x600",
      "https://via.placeholder.com/800x600/000000/ffffff"
    ],
    
    "offline_templates": [
      "./templates/cyberpunk_base.png",
      "./templates/glitch_background.jpg",
      "./templates/abstract_pattern.webp"
    ],
    
    "emergency_content": {
      "narratives": [
        "The system is dreaming - are you awake?",
        "Reality is a buffer waiting to overflow",
        "What if this glitch was intentional?",
        "The error is the message"
      ],
      "runes": ["ᚨ", "ᛒ", "ᚠ", "ᛉ"],
      "colors": ["#ff0000", "#00ffff", "#ffff00"]
    }
  },
  
  "monitoring": {
    "health_checks": [
      {
        "name": "image_apis_health",
        "url": "https://picsum.photos/10/10",
        "expected_status": 200,
        "check_interval": 300
      },
      {
        "name": "news_feeds_health", 
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "expected_status": 200,
        "check_interval": 600
      }
    ],
    
    "performance_metrics": {
      "image_load_time_threshold": 5.0,
      "processing_time_threshold": 10.0,
      "memory_usage_threshold": 512
    }
  }
}
